function Copy_getUnreadMessages (roomID){
  const prop = PropertiesService.getScriptProperties();

  // FetchCall parameters declaration
  let url = "https://api.chatwork.com/v2/rooms/" + roomID + "/messages?force=1";
  let params = {
    headers : {"X-ChatWorkToken" : prop.getProperty('API_TOKEN')},
    method : "GET"
  };
  // Actual FetchCall
  let res = UrlFetchApp.fetch(url, params);
  if (res != ""){
  // return 
    let dataArr = JSON.parse(res.getContentText());
    return dataArr;
  }
};
