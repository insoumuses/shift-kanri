function getWorkingMembersArray() {

  // オ：「BotKun」ライブラリーの負担を減るため、あえて使わない？
  let masterDataSheet = SpreadsheetApp.openByUrl("https://docs.google.com/spreadsheets/d/1zr8Vtk5907bohi-qlR6Wr8p1dCiC8CZ0R9GS5RarqcU/");
  let memberDataArray = masterDataSheet.getSheetByName("メンバーデータ").getDataRange().getValues();

  // 出勤予定メンバーだけのリストを作成
  let dataHeaders = memberDataArray.shift();
  console.log(dataHeaders);

  let nameIndex = dataHeaders.indexOf("呼び方"),
      groupIndex = dataHeaders.indexOf("グループ"), //【2026/7/23】追加
      teamIndex = dataHeaders.indexOf("チーム"),
      positionIndex = dataHeaders.indexOf("ポジション"),
      idIndex = dataHeaders.indexOf("CW_ID"),
      statusIndex = dataHeaders.indexOf("出勤設定"),
      willWorkIndex = dataHeaders.indexOf("出勤中");
  // console.log("必要なヘッダーはこちらのインデックス：" + nameIndex + ", " + teamIndex + ", " + positionIndex + ", " + idIndex + ", " + statusIndex + ", " + willWorkIndex);


  //[4-30-26] 渡邊さんが書いたコードをベースに出社メンバーの報告対応
  const workingStatuses = ["R", "前R", "A", "前"];

  const workingMemberRawArray = memberDataArray.filter(
    el => {
      const isWorkingStatus = workingStatuses.includes(el[statusIndex]); // 出勤設定(workingStatuses配列内データ)の判定
      const isCoreNashiMember = coreNashiMembers.includes(el[nameIndex]); // 「シフト名」内の判定

      return isWorkingStatus && !isCoreNashiMember; // 「出勤ステータスがある」かつ「coreNashiMembersに含まれない」
    }
  );


  // 必要な項目だけのオブジェクトで配列を作り直す
  return workingMemberRawArray.map((member) =>
    new SimpleMember(
      member[nameIndex],
      member[groupIndex], //【2026/7/23】追加
      member[teamIndex],
      member[positionIndex],
      member[idIndex],
      member[statusIndex],
      member[willWorkIndex])
  );
}
